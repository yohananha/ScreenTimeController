{
  "name": "screen-time-functions",
  "version": "0.1.0",
  "description": "Firebase Cloud Functions for Screen Time Controller.",
  "main": "lib/index.js",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "firebase emulators:exec --only firestore,auth \"jest --runInBand --coverage\"",
    "test:rules": "firebase emulators:exec --only firestore \"jest --runInBand test/rules\"",
    "test:unit": "jest --runInBand src/__tests__"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.14.0",
    "firebase-functions-test": "^3.3.0",
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.1.0",
    "firebase-tools": "^13.23.0"
  }
}
